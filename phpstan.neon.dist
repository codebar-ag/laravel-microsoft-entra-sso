includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 9
    paths:
        - src
    tmpDir: var/phpstan
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # Eloquent relation generics use an invariant declaring model; morphOne() returns MorphOne<Related, $this>.
        - '#microsoftIdentity\(\) should return#'
