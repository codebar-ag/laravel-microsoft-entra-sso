{
    "name": "codebar-ag/laravel-microsoft-entra-sso",
    "description": "Microsoft Entra ID SSO authentication for Laravel via OAuth2 + OIDC",
    "keywords": [
        "codebar-ag",
        "laravel",
        "entra",
        "sso",
        "microsoft",
        "azure-ad",
        "entra-id",
        "oauth2",
        "oidc"
    ],
    "homepage": "https://github.com/codebar-ag/laravel-microsoft-entra-sso",
    "license": "MIT",
    "authors": [
        {
            "name": "Codebar AG",
            "email": "info@codebar.ch",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0||^12.0",
        "illuminate/http": "^11.0||^12.0",
        "illuminate/routing": "^11.0||^12.0",
        "illuminate/support": "^11.0||^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.24",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "CodebarAg\\MicrosoftEntraSSO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodebarAg\\MicrosoftEntraSSO\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=100",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --level=5 src",
        "quality": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodebarAg\\MicrosoftEntraSSO\\MicrosoftEntraSSOServiceProvider"
            ],
            "aliases": {
                "MicrosoftEntraSSO": "CodebarAg\\MicrosoftEntraSSO\\Facades\\MicrosoftEntraSSO"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
